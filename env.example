# --- World App / World ID (Developer Portal: https://developer.worldcoin.org) ---
# App ID from the Developer Portal (used by MiniKit and as fallback for verification)
NEXT_PUBLIC_APP_ID=app_your_app_id_here

# World ID 4.0 Relying Party credentials (register an RP in the Developer Portal).
# Required by /api/identity/rp-context and /api/identity/verify.
RP_ID=rp_your_rp_id_here
RP_SIGNING_KEY=your_rp_ecdsa_signing_key_hex

# Developer Portal API key — required by /api/payments/confirm to verify
# pay transactions via developer.worldcoin.org/api/v2/minikit/transaction.
DEV_PORTAL_API_KEY=api_your_dev_portal_key_here

# --- Payments (tips / boosts) ---
# Recipient wallet for tips. Must be whitelisted for the Pay command in the
# Developer Portal (or whitelisting disabled there).
NEXT_PUBLIC_TIP_RECIPIENT_ADDRESS=0xYourRecipientAddress
# Tip amount in WLD
NEXT_PUBLIC_TIP_AMOUNT=1

# --- Supabase ---
# Public client (browser: realtime chat subscription)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Server-only key — required by all API routes (sessions, chat, payments).
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
